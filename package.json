{
  "name": "gemma4",
  "displayName": "gemma4",
  "description": "this is a extension that will help us to enable gemma4 like claude code.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/darshil89/gemma4-vscode-extension"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gemma.openChat",
        "title": "Gemma: Open Chat"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gemma",
          "title": "Gemma Chat",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "gemma": [
        {
          "type": "webview",
          "id": "gemmaChat",
          "name": "Gemma Chat",
          "icon": "https://ollama.com/assets/library/gemma4/d698dd59-9f30-44f9-81b1-a7620010c005"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "undici-types": "^8.1.0"
  }
}
